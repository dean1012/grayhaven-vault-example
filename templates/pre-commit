#!/usr/bin/env bash
set -euo pipefail

required_vault_files=(
  "vault/common.yml"
  "vault/bastion.yml"
  "vault/web.yml"
)

failures=()
vault_header="\$ANSIBLE_VAULT"
lint_files=(
  "config.yml"
  "firewall.yml"
)

is_vault_encrypted() {
  local first_line

  first_line="$(head -n 1 "$1" 2>/dev/null || true)"
  [[ "$first_line" == "$vault_header"* ]]
}

is_staged_vault_encrypted() {
  local first_line

  first_line="$(git show ":$1" 2>/dev/null | head -n 1 || true)"
  [[ "$first_line" == "$vault_header"* ]]
}

for vault_file in "${required_vault_files[@]}"; do
  if [[ ! -f "$vault_file" ]]; then
    failures+=("$vault_file is missing")
    continue
  fi

  if ! is_vault_encrypted "$vault_file"; then
    failures+=("$vault_file is not encrypted in the working tree")
  fi

  if git diff --cached --name-only --diff-filter=ACMR | grep -Fxq "$vault_file"; then
    if ! is_staged_vault_encrypted "$vault_file"; then
      failures+=("$vault_file is not encrypted in the staged commit")
    fi
  fi
done

if ! yamllint "${lint_files[@]}"; then
  failures+=("YAML lint failed")
fi

if ((${#failures[@]} > 0)); then
  printf 'Commit rejected: vault validation failed.\n' >&2
  printf '\n' >&2
  printf 'Failures:\n' >&2
  printf '  - %s\n' "${failures[@]}" >&2
  printf '\n' >&2
  printf 'Encrypt vault files with ansible-vault before committing.\n' >&2
  exit 1
fi

printf 'Vault validation passed.\n'
